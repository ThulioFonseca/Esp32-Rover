{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "UGV Command System (GCS) — ESP32 Rover Ground Control Station. Dual-theme: light ('Field Command') and dark ('Phantom Ops').",

  "color": {
    "$description": "Semantic color tokens. Light theme is default; dark theme overrides via [data-theme='dark'].",

    "light": {
      "$description": "Field Command — F-35 daylight MFD, amber on slate-grey",
      "baseBg":        { "$value": "#c8d0d8",                   "$type": "color", "$description": "App background — slate grey" },
      "cardBg":        { "$value": "rgba(198,210,220,0.97)",    "$type": "color", "$description": "Card surface background" },
      "cardBorder":    { "$value": "rgba(160,90,10,0.22)",      "$type": "color", "$description": "Card border — amber tint" },
      "textMain":      { "$value": "#1a1208",                   "$type": "color", "$description": "Primary text — near-black warm" },
      "textMuted":     { "$value": "#60504a",                   "$type": "color", "$description": "Secondary/muted text — warm brown" },
      "accent":        { "$value": "#c87800",                   "$type": "color", "$description": "Primary accent — amber/orange" },
      "accentHover":   { "$value": "#a86200",                   "$type": "color", "$description": "Accent hover — deeper amber" },
      "accentText":    { "$value": "#ffffff",                   "$type": "color", "$description": "Text on accent backgrounds" },
      "accentGlow":    { "$value": "rgba(200,120,0,0.12)",      "$type": "color", "$description": "Accent subtle fill/glow" },
      "danger":        { "$value": "#c41828",                   "$type": "color", "$description": "Danger / armed / error — red (watermelon)" },
      "warning":       { "$value": "#b06000",                   "$type": "color", "$description": "Warning state — dark amber" },
      "sapphire":      { "$value": "#0055aa",                   "$type": "color", "$description": "Throttle/steering channel highlight — blue" },
      "ironGrey":      { "$value": "#8a8070",                   "$type": "color", "$description": "Neutral border / unit text" },
      "headerBorder":  { "$value": "rgba(160,90,10,0.18)",      "$type": "color", "$description": "Header / frame dividers" },
      "listBorder":    { "$value": "rgba(160,90,10,0.1)",       "$type": "color", "$description": "List item separators" },
      "inputBg":       { "$value": "rgba(255,255,255,0.75)",    "$type": "color", "$description": "Input field background" },
      "inputBorder":   { "$value": "rgba(160,90,10,0.28)",      "$type": "color", "$description": "Input field border" },
      "switchBg":      { "$value": "rgba(0,0,0,0.12)",          "$type": "color", "$description": "Toggle switch track (off)" },
      "switchThumb":   { "$value": "#ffffff",                   "$type": "color", "$description": "Toggle switch thumb" }
    },

    "dark": {
      "$description": "Phantom Ops — night-vision phosphor, matches HUD palette",
      "baseBg":        { "$value": "#060810",                   "$type": "color", "$description": "App background — near-black navy" },
      "cardBg":        { "$value": "rgba(12,19,32,0.96)",       "$type": "color", "$description": "Card surface background" },
      "cardBorder":    { "$value": "rgba(0,255,157,0.15)",      "$type": "color", "$description": "Card border — phosphor green tint" },
      "textMain":      { "$value": "#c8e8d8",                   "$type": "color", "$description": "Primary text — pale phosphor green" },
      "textMuted":     { "$value": "#3a6050",                   "$type": "color", "$description": "Secondary/muted text — dark teal" },
      "accent":        { "$value": "#00ff9d",                   "$type": "color", "$description": "Primary accent — neon phosphor green" },
      "accentHover":   { "$value": "#00d985",                   "$type": "color", "$description": "Accent hover — slightly dimmer green" },
      "accentText":    { "$value": "#060810",                   "$type": "color", "$description": "Text on accent backgrounds — near-black" },
      "accentGlow":    { "$value": "rgba(0,255,157,0.1)",       "$type": "color", "$description": "Accent subtle fill/glow" },
      "danger":        { "$value": "#ff2040",                   "$type": "color", "$description": "Danger / armed / error — bright red" },
      "warning":       { "$value": "#ffb300",                   "$type": "color", "$description": "Warning state — amber" },
      "sapphire":      { "$value": "#00b8e6",                   "$type": "color", "$description": "Throttle/steering channel highlight — cyan" },
      "ironGrey":      { "$value": "#1a3828",                   "$type": "color", "$description": "Neutral border / unit text — dark teal" },
      "headerBorder":  { "$value": "rgba(0,255,157,0.12)",      "$type": "color", "$description": "Header / frame dividers" },
      "listBorder":    { "$value": "rgba(0,255,157,0.06)",      "$type": "color", "$description": "List item separators" },
      "inputBg":       { "$value": "rgba(0,0,0,0.45)",          "$type": "color", "$description": "Input field background" },
      "inputBorder":   { "$value": "rgba(0,255,157,0.2)",       "$type": "color", "$description": "Input field border" },
      "switchBg":      { "$value": "rgba(0,0,0,0.6)",           "$type": "color", "$description": "Toggle switch track (off)" },
      "switchThumb":   { "$value": "#3a6050",                   "$type": "color", "$description": "Toggle switch thumb — teal" }
    },

    "hud": {
      "$description": "HUD viewport fixed tokens — phosphor scope, theme-independent",
      "primary":       { "$value": "#00e87a",                   "$type": "color", "$description": "HUD phosphor green — all SVG strokes, bars" },
      "primaryDim":    { "$value": "rgba(0,232,122,0.2)",       "$type": "color", "$description": "Dimmed HUD elements" },
      "warning":       { "$value": "#ffb300",                   "$type": "color", "$description": "Battery / power bar" },
      "textDim":       { "$value": "rgba(224,248,245,0.65)",    "$type": "color", "$description": "HUD dim text" }
    },

    "terminal": {
      "$description": "Log console / boot screen — hardcoded (outside token system)",
      "bg":            { "$value": "#020604",                   "$type": "color", "$description": "Terminal background" },
      "text":          { "$value": "#00e87a",                   "$type": "color", "$description": "Terminal text" }
    },

    "chart": {
      "$description": "Multi-series sensor chart palette. 6 distinct colors per theme for line charts in the Sensors tab. Colors 1–4 reuse semantic tokens; 5–6 are new additions.",
      "light": {
        "$description": "Field Command chart palette — saturated, military-legible on slate-grey background",
        "series1":  { "$value": "#0055aa",  "$type": "color", "$description": "Series 1 — sapphire blue (reuses sapphire)" },
        "series2":  { "$value": "#c41828",  "$type": "color", "$description": "Series 2 — watermelon red (reuses danger)" },
        "series3":  { "$value": "#c87800",  "$type": "color", "$description": "Series 3 — amber (reuses accent)" },
        "series4":  { "$value": "#b06000",  "$type": "color", "$description": "Series 4 — dark amber (reuses warning)" },
        "series5":  { "$value": "#1a7a4a",  "$type": "color", "$description": "Series 5 — military green (new)" },
        "series6":  { "$value": "#6b21a8",  "$type": "color", "$description": "Series 6 — deep purple (new)" }
      },
      "dark": {
        "$description": "Phantom Ops chart palette — neon, high-contrast on near-black background",
        "series1":  { "$value": "#00b8e6",  "$type": "color", "$description": "Series 1 — cyan (reuses sapphire)" },
        "series2":  { "$value": "#ff2040",  "$type": "color", "$description": "Series 2 — bright red (reuses danger)" },
        "series3":  { "$value": "#00ff9d",  "$type": "color", "$description": "Series 3 — neon green (reuses accent)" },
        "series4":  { "$value": "#ffb300",  "$type": "color", "$description": "Series 4 — amber (reuses warning)" },
        "series5":  { "$value": "#c084fc",  "$type": "color", "$description": "Series 5 — neon purple (new)" },
        "series6":  { "$value": "#fb923c",  "$type": "color", "$description": "Series 6 — neon orange (new)" }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "display":  { "$value": "'Rajdhani', 'Arial Narrow', Arial, sans-serif",    "$type": "fontFamily", "$description": "UI labels, headings, tabs, buttons" },
      "mono":     { "$value": "'JetBrains Mono', 'Courier New', monospace",       "$type": "fontFamily", "$description": "Data readouts, inputs, badges" },
      "hudMono":  { "$value": "'Share Tech Mono', 'Courier New', monospace",      "$type": "fontFamily", "$description": "HUD SVG text and boot console (embedded @font-face)" }
    },

    "fontSize": {
      "xxs":      { "$value": "0.45rem",  "$type": "dimension", "$description": "Accel item labels, tiny HUD elements" },
      "xs":       { "$value": "0.58rem",  "$type": "dimension", "$description": "Firmware version, frame bars, fix badge" },
      "sm":       { "$value": "0.68rem",  "$type": "dimension", "$description": "Header tag (UGV)" },
      "base":     { "$value": "0.72rem",  "$type": "dimension", "$description": "Card h3, channel labels" },
      "md":       { "$value": "0.82rem",  "$type": "dimension", "$description": "Log console" },
      "lg":       { "$value": "0.83rem",  "$type": "dimension", "$description": "Tab buttons, custom inputs" },
      "xl":       { "$value": "0.95rem",  "$type": "dimension", "$description": "Sensor values" },
      "2xl":      { "$value": "1.4rem",   "$type": "dimension", "$description": "H1 title (mobile)" },
      "3xl":      { "$value": "1.75rem",  "$type": "dimension", "$description": "H1 title (desktop)" }
    },

    "fontWeight": {
      "normal":   { "$value": "400", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },

    "letterSpacing": {
      "none":     { "$value": "0",    "$type": "dimension" },
      "xs":       { "$value": "1px",  "$type": "dimension", "$description": "Sensor labels" },
      "sm":       { "$value": "2px",  "$type": "dimension", "$description": "Tabs, connection status, buttons" },
      "md":       { "$value": "3px",  "$type": "dimension", "$description": "H1, card h3 headers" },
      "lg":       { "$value": "5px",  "$type": "dimension", "$description": "Header tag (UGV callsign)" }
    },

    "lineHeight": {
      "tight":    { "$value": "1",   "$type": "dimension", "$description": "Headings, data rows" },
      "normal":   { "$value": "1.1", "$type": "dimension", "$description": "Mobile data rows" },
      "relaxed":  { "$value": "1.5", "$type": "dimension", "$description": "Log console" }
    }
  },

  "spacing": {
    "1":  { "$value": "2px",  "$type": "dimension" },
    "2":  { "$value": "3px",  "$type": "dimension" },
    "3":  { "$value": "4px",  "$type": "dimension" },
    "4":  { "$value": "5px",  "$type": "dimension" },
    "5":  { "$value": "6px",  "$type": "dimension" },
    "6":  { "$value": "8px",  "$type": "dimension" },
    "7":  { "$value": "10px", "$type": "dimension" },
    "8":  { "$value": "12px", "$type": "dimension" },
    "9":  { "$value": "14px", "$type": "dimension" },
    "10": { "$value": "16px", "$type": "dimension" },
    "11": { "$value": "20px", "$type": "dimension" },
    "12": { "$value": "22px", "$type": "dimension" },
    "13": { "$value": "24px", "$type": "dimension" },
    "14": { "$value": "28px", "$type": "dimension" },
    "15": { "$value": "40px", "$type": "dimension" }
  },

  "borderRadius": {
    "none":    { "$value": "0",    "$type": "dimension", "$description": "Default — all UI elements are sharp/square" },
    "subtle":  { "$value": "2px",  "$type": "dimension", "$description": "Map layer buttons only" },
    "sm":      { "$value": "3px",  "$type": "dimension", "$description": "Map layer toggle group only" },
    "pill":    { "$value": "34px", "$type": "dimension", "$description": "Toggle slider pill (.slider.round)" },
    "circle":  { "$value": "50%",  "$type": "dimension", "$description": "Toggle thumb (.slider.round:before)" }
  },

  "shadow": {
    "accentGlow": {
      "sm":  { "$value": "0 0 8px rgba(var(--accent-rgb), 0.6)",   "$type": "shadow", "$description": "Header accent line" },
      "md":  { "$value": "0 0 12px rgba(var(--accent-rgb), 0.2)",  "$type": "shadow", "$description": "Button default" },
      "lg":  { "$value": "0 0 20px rgba(var(--accent-rgb), 0.4)",  "$type": "shadow", "$description": "Button hover" }
    },
    "dangerGlow": {
      "sm":  { "$value": "0 0 8px rgba(var(--watermelon-rgb), 0.25)", "$type": "shadow", "$description": "Armed button" }
    },
    "hudGlow": {
      "primary": { "$value": "0 0 5px #00e87a, 0 0 12px rgba(0,232,122,0.35)", "$type": "shadow", "$description": "HUD bar fills and SVG elements" }
    },
    "inset": {
      "vignette": { "$value": "inset 0 0 100px rgba(0,0,0,0.8)", "$type": "shadow", "$description": "HUD frame CRT vignette" },
      "console":  { "$value": "inset 0 0 30px rgba(0,0,0,0.8)",  "$type": "shadow", "$description": "Log console depth" }
    },
    "elevation": {
      "sm": { "$value": "0 1px 4px rgba(0,0,0,0.45)", "$type": "shadow", "$description": "Minimap zoom buttons" }
    }
  },

  "motion": {
    "duration": {
      "instant":  { "$value": "0.1s",  "$type": "duration", "$description": "Real-time bar fill updates" },
      "fast":     { "$value": "0.2s",  "$type": "duration", "$description": "HUD elements, SVG color transitions" },
      "quick":    { "$value": "0.25s", "$type": "duration", "$description": "Armed button states" },
      "normal":   { "$value": "0.3s",  "$type": "duration", "$description": "Cards, tab fade, input focus" },
      "slow":     { "$value": "0.4s",  "$type": "duration", "$description": "Theme toggle — all global properties" },
      "reveal":   { "$value": "0.5s",  "$type": "duration", "$description": "HUD container scale-in reveal" }
    },
    "easing": {
      "linear":   { "$value": "linear",                            "$type": "cubicBezier", "$description": "Real-time data bars" },
      "ease":     { "$value": "ease",                              "$type": "cubicBezier", "$description": "Standard transitions" },
      "spring":   { "$value": "cubic-bezier(0.1, 1, 0.3, 1)",     "$type": "cubicBezier", "$description": "HUD container reveal — overshoot spring" }
    }
  },

  "layout": {
    "maxWidth": { "$value": "900px", "$type": "dimension", "$description": "App container max-width" },
    "gridMinColumn": { "$value": "280px", "$type": "dimension", "$description": "Dashboard grid minimum column width (auto-fit)" },
    "gridGap": {
      "desktop": { "$value": "20px", "$type": "dimension" },
      "mobile":  { "$value": "14px", "$type": "dimension" }
    },
    "homeHeightViewport": { "$value": "80vh", "$type": "dimension", "$description": "Home layout HUD+map panel height" }
  },

  "breakpoint": {
    "lg":          { "$value": "960px", "$type": "dimension", "$description": "Tablet — HUD layout adjusts" },
    "md":          { "$value": "680px", "$type": "dimension", "$description": "Mobile — home layout stacks" },
    "sm":          { "$value": "600px", "$type": "dimension", "$description": "Small mobile — full responsive adjustments" },
    "landscape":   { "$value": "550px", "$type": "dimension", "$description": "Max-height breakpoint for landscape phones" }
  }
}
